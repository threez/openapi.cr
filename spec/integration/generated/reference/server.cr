        around_action(:create_resource, ctx) do
          x_api_key = header_string(ctx, "X-Api-Key")
          _req_headers = {x_api_key: x_api_key}
          body = parse_body(ctx, CreateResourceRequest)
          create_resource(body, _req_headers)
          ctx.response.status_code = 201
        end
      rescue ex : BadRequestResponse
        json_error ctx, ex, 400
      rescue ex : ForbiddenResponse
        json_error ctx, ex, 403
      rescue ex : UnprocessableResponse
        json_error ctx, ex, 422
      rescue ex : ServerErrorResponse
        json_error ctx, ex, 500
      rescue ex : DefaultErrorResponse
        json_error ctx, ex, 500
      rescue ex : Exception
        ctx.response.status_code = 500
        ctx.response.print ex.message
      end
    end
  end
end
